# CFOperator Environment Variables
# Copy this to .env and fill in your values

# Observability
PROMETHEUS_URL=http://your-prometheus-host:9090
LOKI_URL=http://your-loki-host:3100
ALERTMANAGER_URL=http://your-alertmanager-host:9093

# Database
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_DB=cfoperator
POSTGRES_USER=cfoperator
POSTGRES_PASSWORD=your-secure-password-here

# LLM API Keys (optional — only needed for fallback providers)
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Notifications (optional)
SLACK_WEBHOOK_URL=
