# Example secrets - DO NOT commit real secrets!
# Create with: kubectl create secret generic llm-gateway-secrets \
#   --from-literal=groq-api-key=gsk_xxx \
#   --from-literal=anthropic-api-key=sk-ant-xxx

apiVersion: v1
kind: Secret
metadata:
  name: llm-gateway-secrets
type: Opaque
stringData:
  groq-api-key: "gsk_REPLACE_ME"
  anthropic-api-key: "sk-ant-REPLACE_ME"
